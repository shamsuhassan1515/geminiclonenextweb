{
  "project": {
    "name": "Gemini Clone",
    "description": "Gemini Clone Web Application - AI Chat Interface",
    "version": "0.01",
    "author": "shamsuhassan1515",
    "repository": "https://github.com/shamsuhassan1515/geminiclonenextweb"
  },
  "server": {
    "type": "nodejs",
    "port": 1002,
    "host": "0.0.0.0",
    "startCommand": "npm run dev",
    "buildCommand": "npm run build",
    "workingDirectory": "/Users/aydinkaya/开发/chatgpt-web-midjourney-proxy",
    "envFile": ".env"
  },
  "runtime": {
    "nodeVersion": ">=18.0.0",
    "packageManager": "npm"
  },
  "features": {
    "hotReload": true,
    "autoRestart": true,
    "logRotation": true,
    "maxLogSize": "10MB",
    "maxLogFiles": 5
  },
  "monitoring": {
    "healthCheck": {
      "enabled": true,
      "path": "/",
      "interval": 30
    },
    "metrics": {
      "enabled": true,
      "port": 1002
    }
  },
  "proxy": {
    "enabled": true,
    "routes": [
      {
        "path": "/api",
        "target": "http://localhost:1002"
      },
      {
        "path": "/mjapi",
        "target": "http://localhost:1002"
      },
      {
        "path": "/sunoapi",
        "target": "http://localhost:1002"
      },
      {
        "path": "/uploads",
        "target": "http://localhost:1002"
      },
      {
        "path": "/openapi",
        "target": "http://localhost:1002"
      },
      {
        "path": "/luma",
        "target": "http://localhost:1002"
      },
      {
        "path": "/viggle",
        "target": "http://localhost:1002"
      },
      {
        "path": "/runwayml",
        "target": "http://localhost:1002"
      }
    ]
  }
}
