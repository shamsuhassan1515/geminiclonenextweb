{
  "flyenv": {
    "name": "Gemini Clone",
    "description": "Gemini Clone Web Application - AI Chat Interface",
    "version": "0.01",
    "type": "nodejs",
    "port": 1002,
    "workingDirectory": "/Users/a1-6/开发/chatgpt-web-midjourney-proxy",
    "startCommand": "npm run dev",
    "stopCommand": "pkill -f 'vite'",
    "restartCommand": "pkill -f 'vite' && npm run dev",
    "buildCommand": "npm run build",
    "env": {
      "NODE_ENV": "development",
      "PORT": "1002"
    },
    "autoStart": true,
    "restartOnCrash": true,
    "log": {
      "file": "/Users/a1-6/开发/chatgpt-web-midjourney-proxy/logs/flyenv.log",
      "maxSize": "10m",
      "maxFiles": 5
    },
    "features": {
      "hotReload": true,
      "logRotation": true
    },
    "monitoring": {
      "healthCheck": {
        "enabled": true,
        "path": "/",
        "interval": 30
      }
    },
    "proxy": {
      "enabled": true,
      "routes": [
        {
          "path": "/api",
          "target": "http://localhost:1002"
        },
        {
          "path": "/mjapi",
          "target": "http://localhost:1002"
        },
        {
          "path": "/sunoapi",
          "target": "http://localhost:1002"
        },
        {
          "path": "/uploads",
          "target": "http://localhost:1002"
        },
        {
          "path": "/openapi",
          "target": "http://localhost:1002"
        },
        {
          "path": "/luma",
          "target": "http://localhost:1002"
        },
        {
          "path": "/viggle",
          "target": "http://localhost:1002"
        },
        {
          "path": "/runwayml",
          "target": "http://localhost:1002"
        }
      ]
    },
    "author": "shamsuhassan1515",
    "repository": "https://github.com/shamsuhassan1515/geminiclonenextweb",
    "homepage": "http://localhost:1002",
    "icon": "https://raw.githubusercontent.com/shamsuhassan1515/geminiclonenextweb/main/public/pwa-192x192.png"
  }
}